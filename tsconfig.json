{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun", "@cloudflare/workers-types"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@tab/billing": ["packages/billing/src/index.ts"],
      "@tab/context-policy": ["packages/context-policy/src/index.ts"],
      "@tab/contracts": ["packages/contracts/src/index.ts"],
      "@tab/effect-services": ["packages/effect-services/src/index.ts"],
      "@tab/memory-policy": ["packages/memory-policy/src/index.ts"],
      "@tab/redaction": ["packages/redaction/src/index.ts"],
      "@tab/suggestion-policy": ["packages/suggestion-policy/src/index.ts"],
      "@tab/ui": ["packages/ui/src/index.ts"],
      "@tab/ui/*": ["packages/ui/src/*"]
    },

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx", "index.ts", "worker-configuration.d.ts"]
}
