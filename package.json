{
  "name": "tabb",
  "type": "module",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.mjs && bun test",
    "api:dev": "PORT=8787 bun --hot apps/api/src/index.ts",
    "web:dev": "bun run --cwd apps/web dev",
    "dev": "bun scripts/dev.ts",
    "desktop:dev": "bun apps/desktop/scripts/dev.ts",
    "desktop:permissions": "bun run --cwd apps/desktop dev:permissions",
    "sandcastle": "bun --env-file=.sandcastle/.env .sandcastle/main.ts",
    "sandcastle:verify-gh": "bun --env-file=.sandcastle/.env .sandcastle/verify-gh.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@types/bun": "latest",
    "tailwindcss": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "zod": "^4.4.3"
  }
}
