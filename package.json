{
  "name": "tabb",
  "type": "module",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.mjs && bun test",
    "desktop:dev": "bun apps/desktop/scripts/dev.ts",
    "sandcastle": "bun --env-file=.sandcastle/.env .sandcastle/main.ts",
    "sandcastle:verify-gh": "bun --env-file=.sandcastle/.env .sandcastle/verify-gh.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "zod": "^4.4.3"
  }
}
