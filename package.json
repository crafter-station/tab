{
  "name": "tab",
  "type": "module",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker:types:check": "bunx wrangler types --check --include-runtime false --env-file .dev.vars.example",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.mjs && bun test",
    "test:web:e2e": "playwright test e2e/web-interactions.e2e.ts",
    "db:generate": "bunx drizzle-kit generate --config=apps/api/drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config=apps/api/drizzle.config.ts",
    "db:migrate:local": "bunx wrangler d1 migrations apply tab-db --local --config wrangler.jsonc",
    "db:migrate:remote": "bunx wrangler d1 migrations apply tab-db --remote --config wrangler.jsonc",
    "api:dev": "bunx wrangler dev --config wrangler.jsonc",
    "web:dev": "bun --env-file=.dev.vars run --cwd apps/web dev",
    "dev": "bun --env-file=.dev.vars scripts/dev.ts",
    "desktop:dev": "bun --env-file=.dev.vars apps/desktop/scripts/dev.ts",
    "desktop:permissions": "bun run --cwd apps/desktop dev:permissions",
    "eval:suggestions": "bun apps/desktop/evals/suggestion-prompt.ts",
    "polar:migrate": "bun --env-file=.dev.vars scripts/polar-migrate-local-first.ts --env-file=.dev.vars",
    "polar:migrate:prod": "bun --env-file=dev.vars.prod scripts/polar-migrate-local-first.ts --env-file=dev.vars.prod",
    "polar:setup": "bun --env-file=.dev.vars scripts/polar-setup.ts --env-file=.dev.vars",
    "polar:setup:prod": "bun --env-file=dev.vars.prod scripts/polar-setup.ts --env-file=dev.vars.prod",
    "polar:verify:prod": "bun --env-file=dev.vars.prod scripts/polar-verify-production.ts --env-file=dev.vars.prod",
    "polar:verify-usage": "bun --env-file=.dev.vars scripts/polar-verify-usage.ts",
    "polar:diagnose-customer": "bun --env-file=.dev.vars scripts/polar-diagnose-customer.ts",
    "polar:retry-outbox": "bunx wrangler d1 execute tab-db --remote --config wrangler.jsonc --command \"UPDATE polar_usage_outbox SET status = 'pending', next_attempt_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now'), lease_owner = NULL, lease_expires_at = NULL, updated_at = strftime('%Y-%m-%dT%H:%M:%fZ', 'now') WHERE status = 'failed'\"",
    "sandcastle": "bun --env-file=.sandcastle/.env .sandcastle/main.ts",
    "sandcastle:verify-gh": "bun --env-file=.sandcastle/.env .sandcastle/verify-gh.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/vite": "latest",
    "@types/bun": "latest",
    "tailwindcss": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@t3-oss/env-core": "^0.13.11",
    "zod": "^4.4.3"
  }
}
