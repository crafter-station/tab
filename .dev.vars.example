# Local development
PORT=8787
WEB_PORT=3000
TAB_API_BASE_URL=http://localhost:8787
TAB_WEB_BASE_URL=http://localhost:3000
TAB_DEVICE_ID=dev-device

# Desktop debug overlay
# Set to 1 to force the typing debug overlay in packaged builds.
# In local desktop dev, the debug overlay is enabled by default unless set to 0.
TAB_DEBUG_TYPING_OVERLAY=1
TAB_SHOW_SETTINGS_ON_START=0

# API auth
BETTER_AUTH_URL=http://localhost:8787
BETTER_AUTH_SECRET=replace-with-at-least-32-characters

# AI providers
GROQ_API_KEY=
AI_GATEWAY_API_KEY=

# Optional: remote D1 migrations
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Optional: web download metadata
TAB_MAC_DOWNLOAD_URL=https://downloads.tab.app/tab.dmg
TAB_DESKTOP_LATEST_VERSION=0.1.0

# Optional: Polar billing and usage metering
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_CHECKOUT_SUCCESS_URL=http://localhost:3000/dashboard
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_SEND_ORGANIZATION_ID=false

# Current local-first Polar resources
POLAR_DEEP_COMPLETE_METER_ID=
POLAR_CREDITS_BENEFIT_ID_PRO_MONTHLY=
POLAR_PRODUCT_ID_PRO_MONTHLY=
POLAR_PRODUCT_ID_PRO_ANNUAL=

# Legacy aliases accepted only while existing environments migrate
POLAR_AUTOCOMPLETE_METER_ID=
POLAR_PRODUCT_ID_FREE=
POLAR_CREDITS_BENEFIT_ID_FREE=
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_MAX=
POLAR_CREDITS_BENEFIT_ID_MAX=

RESEND_API_KEY=
