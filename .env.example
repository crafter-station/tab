# Local development
PORT=8787
TABB_API_BASE_URL=http://localhost:8787
TABB_WEB_BASE_URL=http://localhost:3000
TABB_DEVICE_ID=dev-device

# Desktop debug overlay
# Set to 1 to force the typing debug overlay in packaged builds.
# In local desktop dev, the debug overlay is enabled by default unless set to 0.
TABB_DEBUG_TYPING_OVERLAY=1
TABB_SHOW_SETTINGS_ON_START=0

# API auth
BETTER_AUTH_URL=http://localhost:8787
BETTER_AUTH_SECRET=replace-with-at-least-32-characters

# Suggestion model via Vercel AI Gateway + AI SDK
AI_GATEWAY_API_KEY=

# Optional: web download metadata
TABB_MAC_DOWNLOAD_URL=https://downloads.tabb.app/tabb.dmg
TABB_DESKTOP_LATEST_VERSION=0.1.0

# Optional: Polar billing and usage metering
POLAR_ACCESS_TOKEN=
POLAR_AUTOCOMPLETE_METER_ID=
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_MAX=
POLAR_CHECKOUT_SUCCESS_URL=
POLAR_WEBHOOK_SECRET=
